# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.swc/
/out/

# production
/build
/dist-listener

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env files (can opt-in for commiting if needed)
.env
.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.idea
.run

*storybook.log
.vscode/launch.json

# RBAC (env-specific)
rbac.roles.yaml
