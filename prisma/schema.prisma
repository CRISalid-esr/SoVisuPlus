// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["debian-openssl-1.1.x", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int     @id @default(autoincrement())
  personId Int?    @unique
  person   Person? @relation(fields: [personId], references: [id], onDelete: SetNull)
}

model Person {
  id            Int                @id @default(autoincrement())
  uid           String             @unique
  email         String?            @unique
  displayName   String?
  firstName     String?
  lastName      String?
  identifiers   PersonIdentifier[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  external      Boolean            @default(false)
  user          User?
  contributions Contribution[]
}

model Document {
  id                   Int                @id @default(autoincrement())
  uid                  String             @unique
  publicationDate      String?
  publicationDateStart DateTime?
  publicationDateEnd   DateTime?
  titles               DocumentTitle[]
  abstracts            DocumentAbstract[]
  contributions        Contribution[]
  title_locale_0       String?
  title_locale_1       String?
  title_locale_2       String?
}

model DocumentTitle {
  id         Int      @id @default(autoincrement())
  documentId Int
  language   String // ISO 639-1 code (e.g., 'en', 'fr')
  value      String   @db.VarChar(2000)
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, language]) // Ensure no duplicate languages for the same document
}

model DocumentAbstract {
  id         Int      @id @default(autoincrement())
  documentId Int
  language   String // ISO 639-1 code (e.g., 'en', 'fr')
  value      String   @db.Text
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, language]) // Ensure no duplicate languages for the same document
}

model Contribution {
  id         Int              @id @default(autoincrement()) // Optional: add a unique ID for the relation table
  personId   Int
  documentId Int
  role       ContributionRole
  person     Person           @relation(fields: [personId], references: [id], onDelete: Cascade)
  document   Document         @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([personId, documentId, role]) // Ensure a unique combination of person, document, and role
}

