// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["debian-openssl-1.1.x", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int     @id @default(autoincrement())
  personId Int?    @unique
  person   Person? @relation(fields: [personId], references: [id], onDelete: SetNull)
}

model Person {
  id            Int                @id @default(autoincrement())
  uid           String             @unique
  email         String?            @unique
  firstName     String?
  lastName      String?
  identifiers   PersonIdentifier[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  external      Boolean            @default(false)
  user          User?
  contributions Contribution[]
}

model Document {
  id            Int                @id @default(autoincrement())
  uid           String             @unique
  titles        DocumentTitle[]
  abstracts     DocumentAbstract[]
  contributions Contribution[]
}

model DocumentTitle {
  id         Int      @id @default(autoincrement())
  documentId Int
  language   String // ISO 639-1 code (e.g., 'en', 'fr')
  value      String   @db.VarChar(2000)
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, language]) // Ensure no duplicate languages for the same document
}

model DocumentAbstract {
  id         Int      @id @default(autoincrement())
  documentId Int
  language   String // ISO 639-1 code (e.g., 'en', 'fr')
  value      String   @db.Text
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, language]) // Ensure no duplicate languages for the same document
}

model Contribution {
  id         Int              @id @default(autoincrement()) // Optional: add a unique ID for the relation table
  personId   Int
  documentId Int
  role       ContributionRole
  person     Person           @relation(fields: [personId], references: [id], onDelete: Cascade)
  document   Document         @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([personId, documentId, role]) // Ensure a unique combination of person, document, and role
}

enum ContributionRole {
  ACTOR                  @map("actor")
  ADAPTER                @map("adapter")
  ARTIST                 @map("artist")
  AUTHOR                 @map("author")
  AUTHOR_OF_INTRODUCTION @map("author_of_introduction")
  BUILDER                @map("builder")
  BINDER                 @map("binder")
  COMMENTATOR            @map("commentator")
  COMPILER               @map("compiler")
  CONTRIBUTOR            @map("contributor")
  CONDUCTOR              @map("conductor")
  CREATOR                @map("creator")
  DEBATER                @map("debater")
  DANCER                 @map("dancer")
  DIRECTOR               @map("director")
  DESIGNER               @map("designer")
  EDITOR                 @map("editor")
  ENFORCER               @map("enforcer")
  ENGRAVER               @map("engraver")
  EXECUTIVE_PRODUCER     @map("executive_producer")
  FUNDER                 @map("funder")
  GRADER                 @map("grader")
  ILLUSTRATOR            @map("illustrator")
  LABORATOR              @map("laborator")
  LENDER                 @map("lender")
  LIBRARIAN              @map("librarian")
  MANAGER                @map("manager")
  OPERATOR               @map("operator")
  ORGANIZER              @map("organizer")
  PERFORMER              @map("performer")
  PARTY                  @map("party")
  PATRON                 @map("patron")
  RECORDED_BY            @map("recorded_by")
  READER                 @map("reader")
  RECEPTOR               @map("receptor")
  RECEPTION              @map("reception")
  SCORER                 @map("scorer")
  SCRIPTWRITER           @map("scriptwriter")
  SPOKESPERSON           @map("spokesperson")
  SESSION_CREATOR        @map("session_creator")
  TRANSCRIBER            @map("transcriber")
  TRANSLATOR             @map("translator")
  VIDEO_PRODUCER         @map("video_producer")
}

enum PersonIdentifierType {
  ORCID      @map("orcid")
  IDREF      @map("idref")
  ID_HAL_S   @map("id_hal_s")
  ID_HAL_I   @map("id_hal_i")
  SCOPUS_EID @map("scopus_eid")
  LOCAL      @map("local")
}

model PersonIdentifier {
  id       Int                  @id @default(autoincrement())
  type     PersonIdentifierType
  value    String
  person   Person               @relation(fields: [personId], references: [id], onDelete: Cascade)
  personId Int

  @@unique([type, value])
}

model ResearchStructure {
  id           Int                            @id @default(autoincrement())
  uid          String                         @unique
  acronym      String?
  names        ResearchStructureName[]
  descriptions ResearchStructureDescription[] // Separate table for descriptions
  identifiers  ResearchStructureIdentifier[]
}

model ResearchStructureName {
  id                  Int               @id @default(autoincrement())
  researchStructureId Int
  language            String // ISO 639-1 code
  value               String            @db.VarChar(255)
  researchStructure   ResearchStructure @relation(fields: [researchStructureId], references: [id], onDelete: Cascade)

  @@unique([researchStructureId, language])
}

model ResearchStructureDescription {
  id                  Int               @id @default(autoincrement())
  researchStructureId Int
  language            String // ISO 639-1 code
  value               String            @db.VarChar(2000)
  researchStructure   ResearchStructure @relation(fields: [researchStructureId], references: [id], onDelete: Cascade)

  @@unique([researchStructureId, language])
}

model ResearchStructureIdentifier {
  id                  Int                             @id @default(autoincrement())
  type                ResearchStructureIdentifierType
  value               String
  researchStructure   ResearchStructure               @relation(fields: [researchStructureId], references: [id], onDelete: Cascade)
  researchStructureId Int

  @@unique([type, value])
}

enum ResearchStructureIdentifierType {
  LOCAL @map("local")
  RNSR  @map("rnsr")
  IDREF @map("idref")
  ROR   @map("ror")
}
