// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["debian-openssl-1.1.x", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int     @id @default(autoincrement())
  personId Int?    @unique
  person   Person? @relation(fields: [personId], references: [id], onDelete: SetNull)
}

model Person {
  id          Int                @id @default(autoincrement())
  uid         String             @unique
  email       String?            @unique
  firstName   String
  lastName    String
  identifiers PersonIdentifier[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  external    Boolean            @default(false)
  user        User?
}

model Publication {
  id     Int      @id @default(autoincrement())
  uid    String   @unique
  titles String[]
}

enum PersonIdentifierType {
  ORCID      @map("orcid")
  IDREF      @map("idref")
  ID_HAL_S   @map("id_hal_s")
  ID_HAL_I   @map("id_hal_i")
  SCOPUS_EID @map("scopus_eid")
  LOCAL      @map("local")
}

model PersonIdentifier {
  id       Int                  @id @default(autoincrement())
  type     PersonIdentifierType
  value    String
  person   Person               @relation(fields: [personId], references: [id], onDelete: Cascade)
  personId Int

  @@unique([type, value])
}

model ResearchStructure {
  id           Int                           @id @default(autoincrement())
  uid          String                        @unique
  acronym      String?
  identifiers  ResearchStructureIdentifier[]
  names        Json                          @db.JsonB // Store internationalized names
  descriptions Json                          @db.JsonB // Store internationalized descriptions
}

model ResearchStructureIdentifier {
  id                  Int                             @id @default(autoincrement())
  type                ResearchStructureIdentifierType
  value               String
  researchStructure   ResearchStructure               @relation(fields: [researchStructureId], references: [id], onDelete: Cascade)
  researchStructureId Int

  @@unique([type, value])
}

enum ResearchStructureIdentifierType {
  LOCAL @map("local")
  RNSR  @map("rnsr")
  IDREF @map("idref")
  ROR   @map("ror")
}
