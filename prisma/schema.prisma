// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["debian-openssl-1.1.x", "native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int               @id @default(autoincrement())
  email           String            @unique
  AgentIdentifier AgentIdentifier[]
}

model Publication {
  id     Int      @id @default(autoincrement())
  uid    String   @unique
  titles String[]
}

enum AgentIdentifierType {
  ORCID      @map("orcid")
  IDREF      @map("idref")
  ID_HAL_S   @map("id_hal_s")
  ID_HAL_I   @map("id_hal_i")
  SCOPUS_EID @map("scopus_eid")
  LOCAL      @map("local")
}

model AgentIdentifier {
  id     Int                 @id @default(autoincrement())
  type   AgentIdentifierType
  value  String              @unique
  userId Int
  user   User                @relation(fields: [userId], references: [id])
}
