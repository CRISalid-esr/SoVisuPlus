{
  "name": "sovisuplus",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H sovisuplus.local -p 3000",
    "build": "next build",
    "build:custom": "cross-env NEXT_PUBLIC_INSTITUTIONAL=custom next build",
    "dev:custom": "cross-env NEXT_PUBLIC_INSTITUTIONAL=custom next dev",
    "dev:listener": "ts-node --project tsconfig.listener.json src/scripts/listener.ts",
    "dev:relators": "ts-node --project tsconfig.listener.json src/scripts/generateRelators.ts",
    "build:listener": "tsc --project tsconfig.listener.json --outDir dist-listener && npx tsc-alias --project tsconfig.listener.json --outDir dist-listener",
    "start:listener": "node dist-listener/src/scripts/listener.js",
    "start:web": "next start",
    "start:all": "concurrently \"HOSTNAME=\"0.0.0.0\" npm run start:web\" \"npm run start:listener\"",
    "lint": "next lint",
    "test": "jest --config jest.config.ts",
    "test:integration": "jest --runInBand --config jest.integration.config.ts",
    "test:all": "npm run test && npm run test:integration",
    "type-check": "tsc --noEmit",
    "i18n:extract": "lingui extract --clean",
    "i18n:compile": "lingui compile",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "husky",
    "init_roles": "ts-node --project tsconfig.listener.json src/scripts/init_roles.ts",
    "init_roles:js": "node dist-listener/src/scripts/init_roles.js",
    "assign_role": "ts-node --project tsconfig.listener.json src/scripts/assign_role.ts",
    "assign_role:js": "node dist-listener/src/scripts/assign_role.js"
  },
  "dependencies": {
    "@apollo/client": "^3.12.3",
    "@auth/core": "^0.34.2",
    "@casl/ability": "^6.7.3",
    "@casl/react": "^5.0.0",
    "@chromatic-com/storybook": "^3.2.2",
    "@emotion/cache": "^11.13.1",
    "@emotion/react": "^11.14.0",
    "@emotion/server": "^11.11.0",
    "@emotion/styled": "^11.14.0",
    "@fontsource/material-icons": "^5.1.0",
    "@fontsource/roboto": "^5.1.0",
    "@kit-data-manager/react-pid-component": "^0.1.6",
    "@lingui/cli": "^4.14.0",
    "@lingui/loader": "^4.14.0",
    "@lingui/macro": "^4.14.0",
    "@lingui/react": "^4.14.0",
    "@lingui/swc-plugin": "^4.1.0",
    "@mui/icons-material": "^6.4.4",
    "@mui/material": "^6.4.3",
    "@mui/material-nextjs": "^6.1.6",
    "@mui/styles": "^6.1.8",
    "@mui/system": "^6.1.7",
    "@mui/x-date-pickers": "^7.26.0",
    "@prisma/client": "^6.16.2",
    "@storybook/addon-essentials": "^8.4.6",
    "@storybook/addon-interactions": "^8.4.6",
    "@storybook/addon-onboarding": "^8.4.6",
    "@storybook/addon-themes": "^8.4.6",
    "@storybook/blocks": "^8.4.6",
    "@storybook/cli": "^8.4.6",
    "@storybook/nextjs": "^8.4.6",
    "@storybook/react": "^8.4.6",
    "@storybook/test": "^8.4.6",
    "@svgr/webpack": "^8.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/amqplib": "^0.10.6",
    "@types/lodash": "^4.17.13",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/react-highlight-words": "^0.20.0",
    "@types/ws": "^8.18.1",
    "@untitled-ui/icons-react": "^0.1.3",
    "amqplib": "^0.10.5",
    "async-sema": "^3.1.1",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.7",
    "graphql": "^16.10.0",
    "iso-639-1": "^3.1.4",
    "keycloak-js": "^26.0.7",
    "lodash.merge": "^4.6.2",
    "material-react-table": "^3.1.0",
    "next": "15.1.2",
    "next-auth": "^4.24.10",
    "notistack": "^3.0.2",
    "prisma": "^6.16.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-highlight-words": "^0.21.0",
    "remove-accents": "^0.5.0",
    "slugify": "^1.6.6",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "ws": "^8.18.3",
