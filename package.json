{
  "name": "sovisuplus",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "dev:listener": "ts-node --project tsconfig.listener.json src/scripts/listener.ts",
    "build:listener": "tsc --project tsconfig.listener.json --outDir dist",
    "start:listener": "node dist/scripts/listener.js",
    "start:web": "npx prisma migrate deploy && next start",
    "start:all": "concurrently \"npm run start:web\" \"npm run start:listener\"",
    "lint": "next lint",
    "test": "jest",
    "test:integration": "jest --config jest.integration.config.ts",
    "test:all": "npm run test && npm run test:integration",
    "type-check": "tsc --noEmit",
    "lingui:extract": "lingui extract",
    "lingui:compile": "lingui compile",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "husky"
  },
